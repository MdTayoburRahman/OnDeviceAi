<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Allow downloading model files from the internet -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".App"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/Ic_luncher"
        android:label="@string/app_name"
        android:roundIcon="@drawable/Ic_luncher"
        android:supportsRtl="true"
        android:theme="@style/Theme.OnDeviceAi">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ModelListActivity"
            android:exported="false" />

        <activity
            android:name=".ChatHistoryActivity"
            android:exported="false"
            android:label="@string/chat_history_title" />

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:label="@string/settings_title" />

    </application>

</manifest>