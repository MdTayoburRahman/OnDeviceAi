<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/card_background"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Model icon -->
        <ImageView
            android:id="@+id/ivModelIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_cloud_download"
            android:padding="10dp"
            android:background="@drawable/status_chip_background"
            app:tint="@color/secondary"
            android:contentDescription="@string/content_desc_model"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Model name -->
        <TextView
            android:id="@+id/tvModelName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:textSize="16sp"
            android:textColor="@color/on_surface"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintEnd_toStartOf="@id/btnDownload"
            app:layout_constraintStart_toEndOf="@id/ivModelIcon"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Model description / size -->
        <TextView
            android:id="@+id/tvModelDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:textSize="12sp"
            android:textColor="@color/on_surface_variant"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintEnd_toStartOf="@id/btnDownload"
            app:layout_constraintStart_toEndOf="@id/ivModelIcon"
            app:layout_constraintTop_toBottomOf="@id/tvModelName" />

        <!-- Already downloaded badge -->
        <TextView
            android:id="@+id/tvDownloaded"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/already_downloaded"
            android:textSize="11sp"
            android:textColor="@color/on_tertiary_container"
            android:background="@drawable/badge_downloaded"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:layout_marginTop="6dp"
            android:layout_marginStart="16dp"
            android:visibility="gone"
            app:layout_constraintStart_toEndOf="@id/ivModelIcon"
            app:layout_constraintTop_toBottomOf="@id/tvModelDescription" />

        <!-- Download button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDownload"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            app:icon="@drawable/ic_download"
            app:iconSize="18dp"
            app:cornerRadius="20dp"
            android:text="@string/btn_download"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>

