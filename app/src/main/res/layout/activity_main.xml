<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <!-- App Header Section -->
    <LinearLayout
        android:id="@+id/headerSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary_container"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:contentDescription="@string/content_desc_ai"
                android:src="@drawable/ic_robot"
                app:tint="@color/primary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textAlignment="textEnd"
                    android:textColor="@color/on_primary_container"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvModelPath"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:alpha="0.8"
                    android:ellipsize="middle"
                    android:singleLine="true"
                    android:text="@string/model_not_loaded"
                    android:textAlignment="textEnd"
                    android:textColor="@color/on_primary_container"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <!-- Chat history button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHistory"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="4dp"
                android:contentDescription="@string/btn_chat_history"
                android:text="@string/btn_chat_history"
                app:icon="@drawable/ic_history"
                app:iconSize="24dp"
                app:iconTint="@color/on_primary_container" />
            <!-- Clear chat button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClearChat"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="4dp"
                android:contentDescription="@string/btn_clear_chat"
                android:text="@string/btn_clear_chat"
                app:icon="@drawable/clear_all_24dp"
                app:iconSize="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnModels"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:contentDescription="@string/btn_models"
                android:text="@string/btn_models"
                android:textSize="12sp"
                app:cornerRadius="20dp"
                app:icon="@drawable/automation_24dp"
                app:iconSize="18dp" />


            <!-- Small progress indicator shown while native resetSession() runs -->
            <ProgressBar
                android:id="@+id/progressResetSession"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:indeterminate="true"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

    <!-- Status Chips Row -->
    <HorizontalScrollView
        android:id="@+id/statusScrollView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerSection">

        <LinearLayout
            android:id="@+id/llStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Timer Chip -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/status_chip_background"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:contentDescription="@string/content_desc_timer"
                    android:src="@drawable/ic_timer" />

                <TextView
                    android:id="@+id/tvGenTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="@string/status_timer_default"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- CPU Chip -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/status_chip_background"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:contentDescription="@string/content_desc_cpu"
                    android:src="@drawable/ic_cpu" />

                <TextView
                    android:id="@+id/tvSysUsage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="@string/status_cpu_default"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- App RAM Chip -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/status_chip_background"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:contentDescription="@string/status_ram"
                    android:src="@drawable/ram_memory_alt_24dp"
                    />

                <TextView
                    android:id="@+id/tvAppRam"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="App: --"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Device RAM Chip -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/status_chip_background"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:contentDescription="@string/status_ram"
                    android:src="@drawable/ram_memory_alt_24dp"
                    />

                <TextView
                    android:id="@+id/tvDeviceRam"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Device: --"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Available RAM Chip -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/status_chip_background"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:contentDescription="@string/status_ram"
                    android:src="@drawable/ram_memory_alt_24dp"
                    />

                <TextView
                    android:id="@+id/tvAvailableRam"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Free: --"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- GPU Chip -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/status_chip_background"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎮"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvGpuChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="GPU: --"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Vulkan Chip -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/status_chip_background"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvVulkanChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Vulkan: --"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Main Content Container -->
    <LinearLayout
        android:id="@+id/outputContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@+id/inputContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusScrollView">


        <!-- Chat History RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvChat"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="3"
            android:clipToPadding="false"
            android:paddingVertical="8dp"
            tools:listitem="@layout/item_chat_ai" />

        <!-- Hidden tvOutput for backward compatibility -->
        <TextView
            android:id="@+id/tvOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        <!-- Hidden scrollOutput for backward compatibility -->
        <ScrollView
            android:id="@+id/scrollOutput"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </ScrollView>

        <!-- AI Log Section -->
        <LinearLayout
            android:id="@+id/logContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginHorizontal="8dp"
            android:layout_marginBottom="8dp"
            android:layout_weight="1"
            android:background="@drawable/log_panel_background"
            android:orientation="vertical"
            android:padding="2dp">

            <!-- Log Header with compound drawable -->
            <TextView
                android:id="@+id/tvLogHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableStart="@drawable/ic_terminal"
                android:drawablePadding="8dp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:text="@string/log_header"
                android:textColor="@color/log_text"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Log Content -->
            <ScrollView
                android:id="@+id/scrollLog"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingHorizontal="12dp">

                <TextView
                    android:id="@+id/tvLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:lineSpacingMultiplier="1.3"
                    android:textColor="@color/log_text"
                    android:textIsSelectable="true"
                    android:textSize="8sp" />
            </ScrollView>
        </LinearLayout>
    </LinearLayout>

    <!-- Input Container - Fixed at bottom -->
    <LinearLayout
        android:id="@+id/inputContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <EditText
            android:id="@+id/etPrompt"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:layout_weight="1"
            android:background="@drawable/input_background"
            android:hint="@string/hint_prompt"
            android:imeOptions="actionSend"
            android:importantForAutofill="no"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="4"
            android:minLines="1"
            android:scrollbars="vertical"
            android:textColor="@color/on_surface"
            android:textColorHint="@color/on_surface_variant"
            android:textSize="15sp"
            tools:ignore="LabelFor" />

        <!-- Generate Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGenerate"
            style="@style/Widget.Material3.Button"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:contentDescription="@string/btn_generate"
            app:backgroundTint="@color/primary"
            app:cornerRadius="28dp"
            app:icon="@drawable/ic_send"
            app:iconGravity="textStart"
            app:iconPadding="0dp" />

        <!-- Stop Button (hidden by default) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStop"
            style="@style/Widget.Material3.Button"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginStart="3dp"
            android:contentDescription="@string/btn_stop"
            android:visibility="gone"
            app:backgroundTint="@color/error"
            app:cornerRadius="28dp"
            app:icon="@drawable/ic_stop"
            app:iconGravity="textStart"
            app:iconPadding="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNewChat"
            style="@style/Widget.Material3.Button"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginStart="3dp"
            android:contentDescription="@string/btn_generate"
            app:backgroundTint="@color/primary"
            app:cornerRadius="28dp"
            app:icon="@drawable/chat_add_on_24"
            app:iconGravity="textStart"
            app:iconPadding="0dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>