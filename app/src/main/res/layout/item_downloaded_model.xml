<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    app:cardBackgroundColor="@color/card_background"
    android:clickable="true"
    android:focusable="true"
    android:layout_margin="5dp"
    android:background="@drawable/dotted_divider"
    android:foreground="?attr/selectableItemBackground">

<androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Model icon -->
        <ImageView
            android:id="@+id/ivModelIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_model"
            android:padding="10dp"
            android:background="@drawable/status_chip_background"
            app:tint="@color/primary"
            android:contentDescription="@string/content_desc_model"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Model name -->
        <TextView
            android:id="@+id/tvModelName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:textSize="16sp"
            android:textColor="@color/on_surface"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintEnd_toStartOf="@id/buttonsContainer"
            app:layout_constraintStart_toEndOf="@id/ivModelIcon"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- File name / size info -->
        <TextView
            android:id="@+id/tvModelInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:textSize="12sp"
            android:textColor="@color/on_surface_variant"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintEnd_toStartOf="@id/buttonsContainer"
            app:layout_constraintStart_toEndOf="@id/ivModelIcon"
            app:layout_constraintTop_toBottomOf="@id/tvModelName" />

        <!-- Buttons container -->
        <LinearLayout
            android:id="@+id/buttonsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Select indicator -->
            <ImageView
                android:id="@+id/ivSelect"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_check_circle"
                app:tint="@color/primary"
                android:visibility="gone"
                android:contentDescription="@string/selected" />

            <!-- Delete button -->
            <ImageButton
                android:id="@+id/btnDelete"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/btn_delete_model"
                app:tint="@color/error" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>


</LinearLayout>
