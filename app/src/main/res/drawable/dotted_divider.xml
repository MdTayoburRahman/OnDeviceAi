<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- height of the drawable when used as a background -->
    <size android:height="1dp" />

    <!-- stroke produces the dotted/dashed effect. Use small dashWidth for dot-like appearance -->
    <stroke
        android:width="1dp"
        android:color="#BDBDBD"
        android:dashWidth="2dp"
        android:dashGap="4dp" />
</shape>
